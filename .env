# ========== nln OpenAI API 配置 ==========
OPENAI_API_KEY=your-key
OPENAI_BASE_URL=https://api.n1n.ai/v1
DEFAULT_MODEL=text-embedding-3-large
OPENAI_MODEL=gpt-5.2

# ========== Google gemini配置 ==========
GOOGLE_API_KEY=your-key

# ========== Deepseek配置 ==========
DEEPSEEK_API_KEY=your-key
DEEPSEEK_BASE_URL=https//api.deepseek.com

# ========== Deepseek Qianw配置 ==========
Qianw_API_KEY=your-key
DEEPSEEK_BASE_URL=https//api.deepseek.com

# ========== 应用配置 ==========
# 环境：development/production/testing
#ENVIRONMENT=development

# 调试模式
#DEBUG=True

# 日志级别：DEBUG/INFO/WARNING/ERROR
#LOG_LEVEL=INFO

# ========== API 限流配置 ==========
# 每分钟最大请求数
#MAX_REQUESTS_PER_MINUTE=60

# 批量处理大小
#BATCH_SIZE=100

# 请求超时时间（秒）
#REQUEST_TIMEOUT=30

# 最大重试次数
#MAX_RETRIES=3

# 重试延迟（秒）
#RETRY_DELAY=1

# ========== 缓存配置 ==========
# 是否启用 embedding 缓存
#ENABLE_CACHE=True

# 缓存大小限制
#CACHE_MAX_SIZE=1000

# 缓存过期时间（秒）
#CACHE_TTL=3600

# ========== 测试配置 ==========
# 测试文本数量
#TEST_SAMPLE_SIZE=10

# 相似度阈值
#SIMILARITY_THRESHOLD=0.7

# 是否生成可视化图表
#GENERATE_VISUALIZATIONS=True
